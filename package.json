{
  "name": "palmera",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "./scripts/build-optimized.sh all",
    "build:fast": "./scripts/build-optimized.sh",
    "build:web-admin": "./scripts/build-optimized.sh web-admin",
    "build:web-provider": "./scripts/build-optimized.sh web-provider", 
    "build:mobile": "./scripts/build-optimized.sh mobile",
    "build:api": "./scripts/build-optimized.sh api",
    "dev": "./scripts/dev-focused.sh full",
    "dev:admin": "./scripts/dev-focused.sh admin",
    "dev:provider": "./scripts/dev-focused.sh provider",
    "dev:mobile": "./scripts/dev-focused.sh mobile",
    "dev:fast": "./scripts/start-dev.sh",
    "lint": "npx pnpm --recursive run lint",
    "lint:fix": "npx pnpm --recursive run lint --fix",
    "test": "npx pnpm --recursive run test",
    "test:unit": "npx pnpm --recursive run test:unit",
    "test:integration": "npx pnpm --recursive run test:integration", 
    "test:e2e": "npx pnpm --recursive run test:e2e",
    "type-check": "npx pnpm --recursive run type-check",
    "type-check:watch": "npx pnpm --recursive run type-check --watch",
    "clean": "npx pnpm --recursive run clean && rm -rf node_modules/.cache",
    "clean:hard": "rm -rf node_modules apps/*/node_modules packages/*/node_modules && pnpm install",
    "db:generate": "cd apps/api && pnpm db:generate",
    "db:push": "cd apps/api && pnpm db:push", 
    "db:migrate": "cd apps/api && pnpm db:migrate",
    "db:seed": "cd apps/api && pnpm db:seed",
    "validate:env": "cd apps/api && pnpm validate:env",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "deps:update": "pnpm update --recursive",
    "deps:check": "pnpm outdated --recursive",
    "frontend": "./scripts/frontend-dev.sh",
    "watch": "./scripts/dev-watch.sh",
    "watch:admin": "./scripts/dev-watch.sh admin",
    "watch:provider": "./scripts/dev-watch.sh provider",
    "watch:mobile": "./scripts/dev-watch.sh mobile"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.2.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0"
  },
  "engines": {
    "node": ">=20.x"
  },
  "packageManager": "pnpm@9.0.0"
}