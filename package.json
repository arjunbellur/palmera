{
  "name": "palmera",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx pnpm --recursive run build",
    "dev": "npx pnpm --recursive run dev",
    "dev:fast": "./scripts/start-dev.sh",
    "lint": "npx pnpm --recursive run lint",
    "test": "npx pnpm --recursive run test",
    "test:unit": "npx pnpm --recursive run test:unit",
    "test:integration": "npx pnpm --recursive run test:integration",
    "test:e2e": "npx pnpm --recursive run test:e2e",
    "type-check": "npx pnpm --recursive run type-check",
    "clean": "npx pnpm --recursive run clean",
    "db:generate": "cd apps/api && npm run db:generate",
    "db:push": "cd apps/api && npm run db:push",
    "db:migrate": "cd apps/api && npm run db:migrate",
    "db:seed": "cd apps/api && npm run db:seed",
    "validate:env": "cd apps/api && npm run validate:env",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.2.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0"
  },
  "engines": {
    "node": "18.x"
  },
  "packageManager": "pnpm@9"
}